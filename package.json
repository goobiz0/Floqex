{
  "name": "floqex-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "cmd.exe /c \"set NODE_OPTIONS=--use-system-ca && prisma generate\"",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "build:worker": "esbuild src/worker/engine.ts --bundle --platform=node --target=node20 --outdir=dist",
    "worker": "node dist/engine.js"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "@emnapi/runtime": "1.11.1",
    "@emnapi/core": "1.11.1"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.46",
    "@ai-sdk/openai": "^3.0.43",
    "@ai-sdk/react": "^3.0.120",
    "@clerk/backend": "^3.8.3",
    "@clerk/nextjs": "^7.5.7",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@notionhq/client": "^5.22.0",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.19.3",
    "@remotion/player": "^4.0.484",
    "@upstash/qstash": "^2.11.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "ai": "^6.0.118",
    "ccxt": "^4.5.59",
    "class-variance-authority": "^0.7.1",
    "gsap": "^3.15.0",
    "lightweight-charts": "^5.2.0",
    "motion": "^12.40.0",
    "next": "16.2.9",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "protobufjs": "^8.6.5",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-grid-layout": "^1.4.4",
    "react-resizable": "^4.0.2",
    "recharts": "^3.9.0",
    "remotion": "^4.0.484",
    "sonner": "^2.0.7",
    "stripe": "^22.2.2",
    "yahoo-finance2": "^3.15.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.2.9",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "@types/react-resizable": "^3.0.8",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  }
}
