// Floqex data model. See the Architecture Overview for the domain design.
// Postgres (Supabase). Money is stored as Decimal; times are UTC.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: pooled URL for the app, direct URL for migrations.
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

// ─────────────────────────── Identity ───────────────────────────

enum Plan {
  FREE
  TRADER
  PRO
  ELITE

  @@schema("public")
}

model User {
  id        String  @id @default(cuid())
  clerkId   String  @unique
  email     String  @unique
  firstName String?
  lastName  String?
  imageUrl  String?

  // Billing (Stripe). `plan` is the entitlement the app gates on; the rest
  // mirror the Stripe subscription and are kept in sync by the webhook.
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  stripeSubStatus        String?
  stripeCurrentPeriodEnd DateTime?

  // Developer & MCP API Access
  // mcpKey stored in Clerk privateMetadata instead of DB to avoid schema migrations

  // Alerting Preferences
  webhookUrl   String?
  alertOnTrade Boolean @default(false)
  alertOnRisk  Boolean @default(true)
  alertOnError Boolean @default(true)

  // Portfolio-level risk controls (Portfolio Risk Command Center). The kill
  // switch (tradingHalted) is enforced server-side in validateRisk, so it stops
  // every bot's next entry regardless of the per-account limits.
  maxPortfolioDrawdown Decimal? @db.Decimal(18, 2)
  tradingHalted        Boolean  @default(false)

  // Extra Balance (Pay-as-you-go)
  extraBalanceUsd Decimal @default(0) @db.Decimal(18, 4)
  useExtraBalance Boolean @default(true)

  // Affiliate Program
  affiliateCode       String? @unique
  referredById        String?
  affiliateBonusPaid  Boolean @default(false)
  affiliateBalanceUsd Decimal @default(0) @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  bots               Bot[]
  strategies         Strategy[]
  dashboardTemplates DashboardTemplate[]
  mochiUsage         MochiUsage[]
  copyLinks          CopyLink[]
  forwardTests       ForwardTest[]

  // Marketplace
  sellerBalance      Decimal  @default(0) @db.Decimal(18, 2)
  sellerCurrency     String   @default("USD")
  payoutEmail        String?
  
  marketplaceListings  MarketplaceListing[]  @relation("MarketplaceSeller")
  marketplacePurchases MarketplacePurchase[] @relation("MarketplaceBuyer")
  marketplaceReviews   MarketplaceReview[]   @relation("MarketplaceReviewer")
  withdrawalRequests   WithdrawalRequest[]
  notifications        Notification[]

  @@map("users")
  @@schema("public")
}

// One Mochi (AI copilot) request's token usage, so we can meter per-plan limits
// over rolling windows (per 5 hours and per week) and show the user what they
// have spent.
model MochiUsage {
  id               String   @id @default(cuid())
  userId           String
  ts               DateTime @default(now())
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ts])
  @@map("mochi_usage")
  @@schema("public")
}

// ─────────────────────── Dashboards ───────────────────────────

model DashboardTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  layout    Json // Array of widget definitions: { id, type, x, y, w, h, config }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dashboard_templates")
  @@schema("public")
}

// ─────────────────────── Accounts & Bots ────────────────────────

enum Broker {
  PAPER
  OANDA
  IBKR
  TRADOVATE
  ALPACA
  COINBASE
  BINANCE
  KRAKEN
  SCHWAB

  @@schema("public")
}

enum AccountMode {
  PAPER
  LIVE

  @@schema("public")
}

model Account {
  id                          String      @id @default(cuid())
  userId                      String
  nickname                    String
  broker                      Broker      @default(PAPER)
  mode                        AccountMode @default(PAPER)
  externalId                  String?
  balance                     Decimal     @default(10000) @db.Decimal(18, 2)
  currency                    String      @default("USD")
  maxDailyDrawdown            Decimal?    @db.Decimal(18, 2)
  isPropFirmMode              Boolean     @default(false)
  propFirmMaxTrailingDrawdown Decimal?    @db.Decimal(18, 2)
  isActive                    Boolean     @default(true)
  createdAt                   DateTime    @default(now())
  updatedAt                   DateTime    @updatedAt

  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot               Bot?
  connection        Connection?
  trades            Trade[]
  summaries         DailySummary[]
  agentEvents       AgentEvent[]
  // Copy trading: an account can lead one or more follower accounts (as master)
  // and/or mirror a single master (as follower). The links carry the routing.
  copyMasterLinks   CopyLink[]     @relation("CopyMaster")
  copyFollowerLinks CopyLink[]     @relation("CopyFollower")
  forwardTests      ForwardTest[]

  @@unique([id, userId])
  @@index([userId])
  @@map("accounts")
  @@schema("public")
}

enum BotStatus {
  RUNNING
  WAITING
  STOPPED

  @@schema("public")
}

model Bot {
  id                  String    @id @default(cuid())
  userId              String
  accountId           String?   @unique
  strategyId          String
  name                String    @default("My Bot")
  status              BotStatus @default(STOPPED)
  // Which assets THIS bot trades. Assets live on the bot, not the strategy, so
  // the same strategy can drive several bots on different instruments. Empty for
  // bots created before this field existed; the engine falls back to the
  // strategy's params for those (see instrumentsForBot).
  instruments         String[]  @default([])
  autoAdjustmentsUsed Int       @default(0)
  // Share of the portfolio risk budget allocated to this bot (percent).
  riskWeight          Decimal?  @db.Decimal(5, 2)
  // Edge-decay protection: pause flag + the relative win-rate drop that trips it.
  edgeDecayPaused     Boolean   @default(false)
  edgeDecayThreshold  Decimal?  @db.Decimal(5, 2)
  // Public proof-of-execution embed page toggle.
  isPublic            Boolean   @default(false)
  lastHeartbeat       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  strategy    Strategy        @relation(fields: [strategyId], references: [id])
  trades      Trade[]
  adjustments BotAdjustment[]
  agentEvents AgentEvent[]

  @@index([userId])
  @@index([strategyId])
  @@map("bots")
  @@schema("public")
}

// ───────────────────────── Strategies ───────────────────────────

enum StrategyKind {
  ORB
  CUSTOM

  @@schema("public")
}

model Strategy {
  id        String       @id @default(cuid())
  userId    String
  name      String
  kind      StrategyKind @default(ORB)
  // Typed parameter set rendered by the Strategy Lab UI.
  params    Json
  version   Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  bots         Bot[]
  adjustments  BotAdjustment[]
  forwardTests ForwardTest[]
  listings     MarketplaceListing[]

  @@index([userId])
  @@map("strategies")
  @@schema("public")
}

// ─────────────────────────── Trades ─────────────────────────────

enum TradeDirection {
  LONG
  SHORT

  @@schema("public")
}

enum TradeSession {
  ASIA
  NY

  @@schema("public")
}

enum TradeStatus {
  OPEN
  CLOSED

  @@schema("public")
}

model Trade {
  id         String         @id @default(cuid())
  botId      String
  accountId  String
  instrument String
  direction  TradeDirection
  session    TradeSession
  status     TradeStatus    @default(OPEN)

  entryPrice  Decimal  @db.Decimal(18, 5)
  exitPrice   Decimal? @db.Decimal(18, 5)
  stopPrice   Decimal  @db.Decimal(18, 5)
  targetPrice Decimal  @db.Decimal(18, 5)
  sizeUnits   Decimal  @db.Decimal(18, 4)
  riskPct     Decimal  @db.Decimal(6, 3)

  grossPnl   Decimal? @db.Decimal(18, 2)
  commission Decimal? @db.Decimal(18, 2)
  netPnl     Decimal? @db.Decimal(18, 2)
  rMultiple  Decimal? @db.Decimal(8, 3)
  mfe        Decimal? @db.Decimal(8, 3) // max favourable excursion (R)
  mae        Decimal? @db.Decimal(8, 3) // max adverse excursion (R)

  // Execution quality: what the bot intended vs what it actually filled, so a
  // trader can see whether automation is faithful (slippage in basis points,
  // positive = adverse) and how fast the entry routed.
  intendedEntryPrice Decimal? @db.Decimal(18, 5)
  entrySlippageBps   Decimal? @db.Decimal(10, 3)
  intendedExitPrice  Decimal? @db.Decimal(18, 5)
  exitSlippageBps    Decimal? @db.Decimal(10, 3)
  entryLatencyMs     Int?

  // Evidence-loop context buckets
  rangeBucket String? // SMALL | MEDIUM | LARGE
  entryBucket String? // FIRST_HOUR | LATER
  trendAgree  Boolean?

  screenshotUrl String?
  narrative     String?

  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, openedAt])
  @@index([botId])
  @@index([accountId, status, closedAt(sort: Desc), openedAt(sort: Desc)])
  @@index([botId, status, closedAt(sort: Desc), openedAt(sort: Desc)])
  @@map("trades")
  @@schema("public")
}

// ───────────────── Evidence-based optimisation ──────────────────

enum AdjustmentSource {
  BOT
  USER

  @@schema("public")
}

enum AdjustmentStatus {
  APPLIED
  PENDING
  REJECTED

  @@schema("public")
}

model BotAdjustment {
  id           String           @id @default(cuid())
  botId        String
  strategyId   String
  // Human-readable parameter label (for display) and the canonical schema key
  // (for application). paramKey lets approveSuggestion apply the change to
  // Strategy.params; oldValue/newValue store the raw values, formatted at render.
  parameter    String
  paramKey     String?
  oldValue     String
  newValue     String
  source       AdjustmentSource @default(BOT)
  status       AdjustmentStatus @default(APPLIED)
  reasoning    String?
  sampleSize   Int?
  winRateDelta Decimal?         @db.Decimal(6, 3)
  confidence   Decimal?         @db.Decimal(6, 3)
  createdAt    DateTime         @default(now())

  bot      Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@map("bot_adjustments")
  @@schema("public")
}

// ───────────────── Forward-test promotion gate ──────────────────

enum ForwardTestStatus {
  RUNNING
  PASSED
  FAILED
  STOPPED

  @@schema("public")
}

// A strategy proving itself in live paper ("shadow") trading before live capital
// is unlocked. Observed metrics are computed from the paper account's closed
// trades and compared to the validation baseline; status flips to PASSED only
// once enough trades confirm the edge held.
model ForwardTest {
  id                 String            @id @default(cuid())
  userId             String
  strategyId         String
  accountId          String
  status             ForwardTestStatus @default(RUNNING)
  targetTrades       Int               @default(20)
  baselineWinRate    Decimal?          @db.Decimal(6, 3)
  baselineExpectancy Decimal?          @db.Decimal(8, 3) // R per trade
  startedAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@map("forward_tests")
  @@schema("public")
}

// ─────────────────────── Daily summaries ────────────────────────

model DailySummary {
  id           String   @id @default(cuid())
  accountId    String
  date         DateTime @db.Date
  netPnl       Decimal  @default(0) @db.Decimal(18, 2)
  tradeCount   Int      @default(0)
  winCount     Int      @default(0)
  lossCount    Int      @default(0)
  startBalance Decimal  @db.Decimal(18, 2)
  endBalance   Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("daily_summaries")
  @@schema("public")
}

// ───────────────────────── News events ──────────────────────────

enum NewsImpact {
  LOW
  MEDIUM
  HIGH

  @@schema("public")
}

model NewsEvent {
  id        String     @id @default(cuid())
  eventTime DateTime
  currency  String
  impact    NewsImpact
  name      String
  createdAt DateTime   @default(now())

  @@index([eventTime])
  @@map("news_events")
  @@schema("public")
}

// ──────────────────── Broker connections (live) ─────────────────

// Encrypted broker credentials for a live account. `encrypted` holds an
// AES-256-GCM ciphertext (see src/lib/crypto.ts); secrets are never returned to
// the client and are decrypted only by the trading engine to place orders.
model Connection {
  id             String    @id @default(cuid())
  accountId      String    @unique
  provider       String
  encrypted      String
  status         String    @default("CONNECTED")
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("connections")
  @@schema("public")
}

// ───────────────────────── Agent feed ───────────────────────────

enum AgentEventKind {
  INFO
  SIGNAL
  TRADE
  RISK
  NEWS
  ADJUST

  @@schema("public")
}

// One narrated decision from the engine, powering the live agent feed.
// Trade.narrative remains the trade-level summary; this is the per-event stream.
model AgentEvent {
  id        String         @id @default(cuid())
  botId     String
  accountId String
  ts        DateTime       @default(now())
  kind      AgentEventKind @default(INFO)
  message   String
  tradeId   String?

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, ts])
  @@map("agent_events")
  @@schema("public")
}

// ─────────────────────── Copy trading (paid) ────────────────────

// How a follower's order size is derived from the master's fill. The engine
// maps each mode to a size in src/lib/engine/copy-trading.ts.
enum CopySizingMode {
  MIRROR // same size as the master order
  MULTIPLIER // master size * multiplier
  PROPORTIONAL // scale by equity ratio (follower balance / master balance) * multiplier
  FIXED // a fixed unit size on every copied trade

  @@schema("public")
}

enum CopyFilterMode {
  ALLOW
  DENY

  @@schema("public")
}

enum CopyLinkStatus {
  ACTIVE
  PAUSED

  @@schema("public")
}

// One master account fanning trades out to one follower account. The pair is
// unique, so a follower mirrors at most one master per master. Cross-broker by
// design: master and follower can sit on different brokers; the engine routes
// each follower order through that account's own execution path.
model CopyLink {
  id                String         @id @default(cuid())
  userId            String
  masterAccountId   String
  followerAccountId String
  status            CopyLinkStatus @default(ACTIVE)
  sizingMode        CopySizingMode @default(PROPORTIONAL)
  multiplier        Decimal        @default(1) @db.Decimal(8, 4)
  fixedUnits        Decimal?       @db.Decimal(18, 4)
  maxRiskPct        Decimal?       @db.Decimal(6, 3) // cap risk per copied trade (% of follower equity)
  minUnits          Decimal?       @db.Decimal(18, 4) // floor a copy up to this size (skip dust)
  maxUnits          Decimal?       @db.Decimal(18, 4) // hard ceiling on any copied order
  symbolFilter      String? // comma list of instruments to allow or block
  symbolFilterMode  CopyFilterMode @default(ALLOW) // ALLOW = copy only these, DENY = copy all but these
  maxDailyLossPct   Decimal?       @db.Decimal(6, 3) // auto-pause the link past this daily copied loss
  reverse           Boolean        @default(false) // copy the opposite direction
  copyOpen          Boolean        @default(true)
  copyClose         Boolean        @default(true)
  pausedReason      String? // why the breaker tripped, cleared on resume
  copiedCount       Int            @default(0)
  lastCopiedAt      DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterAccount   Account          @relation("CopyMaster", fields: [masterAccountId, userId], references: [id, userId], onDelete: Cascade)
  followerAccount Account          @relation("CopyFollower", fields: [followerAccountId, userId], references: [id, userId], onDelete: Cascade)
  events          CopyTradeEvent[]

  @@unique([masterAccountId, followerAccountId])
  @@index([userId])
  @@index([masterAccountId])
  @@index([followerAccountId])
  @@map("copy_links")
  @@schema("public")
}

// Audit log of every replication attempt, success or skip, so the user can see
// exactly what mirrored where. followerTradeId ties an OPEN copy back to the
// follower's trade row, which the CLOSE replication then resolves and closes.
model CopyTradeEvent {
  id              String   @id @default(cuid())
  copyLinkId      String?
  sourceTradeId   String
  followerTradeId String?
  action          String // OPEN | CLOSE
  status          String // FILLED | SKIPPED | FAILED
  reason          String?
  instrument      String
  direction       String
  sizeUnits       Decimal? @db.Decimal(18, 4)
  pnl             Decimal? @db.Decimal(18, 2)
  createdAt       DateTime @default(now())
  userId          String

  copyLink CopyLink? @relation(fields: [copyLinkId], references: [id], onDelete: SetNull)

  @@index([copyLinkId, createdAt])
  @@index([sourceTradeId])
  @@map("copy_trade_events")
  @@schema("public")
}

// ─────────────────── Strategy Marketplace ────────────────────────
//
// Sellers list strategies for a fixed price. On every sale the platform keeps
// 30% (inclusive of Stripe processing fees) and credits 70% to the seller's
// in-app balance. Sellers can request payouts once their balance exceeds the
// minimum threshold. Reviews are gated to verified purchasers.

enum ListingStatus {
  DRAFT
  ACTIVE
  PAUSED
  REMOVED

  @@schema("public")
}

model MarketplaceListing {
  id          String        @id @default(cuid())
  sellerId    String
  strategyId  String
  // Public-facing fields
  title       String
  description String        @db.Text
  tagline     String?
  category    String        @default("Breakout")
  priceUsd    Decimal       @db.Decimal(10, 2) // listing price in USD
  status      ListingStatus @default(DRAFT)
  // Aggregated stats (denormalized for fast listing pages)
  salesCount  Int           @default(0)
  reviewCount Int           @default(0)
  avgRating   Decimal       @default(0) @db.Decimal(3, 2) // 0.00 to 5.00
  // Performance snapshot baked at listing time so buyers see real numbers
  edgeScore       Int?
  edgeVerdict     String?
  winRate         Decimal? @db.Decimal(6, 2)
  totalReturnPct  Decimal? @db.Decimal(10, 2)
  maxDrawdownPct  Decimal? @db.Decimal(6, 2)
  tradeCount      Int?
  // Revenue tracking
  totalRevenue    Decimal  @default(0) @db.Decimal(18, 2) // gross sales
  totalPlatformFee Decimal @default(0) @db.Decimal(18, 2)
  totalSellerEarnings Decimal @default(0) @db.Decimal(18, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  seller    User                  @relation("MarketplaceSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  strategy  Strategy              @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  purchases MarketplacePurchase[]
  reviews   MarketplaceReview[]

  @@unique([sellerId, strategyId])
  @@index([status, avgRating(sort: Desc)])
  @@index([status, salesCount(sort: Desc)])
  @@index([category, status])
  @@map("marketplace_listings")
  @@schema("public")
}

enum PurchaseStatus {
  PENDING   // Checkout session created but not yet paid
  COMPLETED // Payment confirmed, strategy cloned to buyer
  REFUNDED  // Full refund issued
  FAILED    // Payment failed or expired

  @@schema("public")
}

model MarketplacePurchase {
  id               String         @id @default(cuid())
  buyerId          String
  listingId        String
  stripeSessionId  String?        @unique // Stripe Checkout Session ID
  stripePaymentId  String?        // Stripe PaymentIntent ID (for refunds)
  status           PurchaseStatus @default(PENDING)
  priceUsd         Decimal        @db.Decimal(10, 2) // price at time of purchase
  platformFeeUsd   Decimal        @db.Decimal(10, 2) // 30% kept by platform
  sellerEarningUsd Decimal        @db.Decimal(10, 2) // 70% credited to seller
  // The cloned strategy given to the buyer (null until payment confirms)
  clonedStrategyId String?
  createdAt        DateTime       @default(now())
  completedAt      DateTime?

  buyer   User               @relation("MarketplaceBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([buyerId])
  @@index([listingId])
  @@index([stripeSessionId])
  @@map("marketplace_purchases")
  @@schema("public")
}

model MarketplaceReview {
  id        String @id @default(cuid())
  buyerId   String
  listingId String
  rating    Int // 1 to 5 stars
  title     String?
  body      String? @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buyer   User               @relation("MarketplaceReviewer", fields: [buyerId], references: [id], onDelete: Cascade)
  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  // One review per buyer per listing
  @@unique([buyerId, listingId])
  @@index([listingId, createdAt(sort: Desc)])
  @@map("marketplace_reviews")
  @@schema("public")
}

enum WithdrawalStatus {
  PENDING    // Seller requested, admin review needed
  PROCESSING // Admin approved, payout in progress
  COMPLETED  // Funds sent
  REJECTED   // Admin rejected (fraud, etc.)

  @@schema("public")
}

model WithdrawalRequest {
  id          String           @id @default(cuid())
  userId      String
  amountUsd   Decimal          @db.Decimal(18, 2)
  status      WithdrawalStatus @default(PENDING)
  payoutEmail String // Email or PayPal address for the payout
  // Admin-managed fields
  processedAt DateTime?
  adminNote   String?
  // Stripe Transfer/Payout reference (if processed via Stripe)
  stripeTransferId String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
  @@map("withdrawal_requests")
  @@schema("public")
}

// ─────────────────────── Notifications ──────────────────────────

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
  @@schema("public")
}
