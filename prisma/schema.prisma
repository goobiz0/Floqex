// Floqex data model. See the Architecture Overview for the domain design.
// Postgres (Supabase). Money is stored as Decimal; times are UTC.

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // Supabase: pooled URL for the app, direct URL for migrations.
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

// ─────────────────────────── Identity ───────────────────────────

enum Plan {
  FREE
  TRADER
  PRO
  ELITE
  @@schema("public")
}

model User {
  id        String   @id @default(cuid())
  clerkId   String   @unique
  email     String   @unique
  firstName String?
  lastName  String?
  imageUrl  String?

  // Billing (Stripe). `plan` is the entitlement the app gates on; the rest
  // mirror the Stripe subscription and are kept in sync by the webhook.
  plan                   Plan      @default(FREE)
  stripeCustomerId       String?   @unique
  stripeSubscriptionId   String?
  stripeSubStatus        String?
  stripeCurrentPeriodEnd DateTime?

  // Developer & MCP API Access
  // mcpKey stored in Clerk privateMetadata instead of DB to avoid schema migrations

  // Alerting Preferences
  webhookUrl           String?
  alertOnTrade         Boolean   @default(false)
  alertOnRisk          Boolean   @default(true)
  alertOnError         Boolean   @default(true)

  // Portfolio-level risk controls (Portfolio Risk Command Center). The kill
  // switch (tradingHalted) is enforced server-side in validateRisk, so it stops
  // every bot's next entry regardless of the per-account limits.
  maxPortfolioDrawdown Decimal?  @db.Decimal(18, 2)
  tradingHalted        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts           Account[]
  bots               Bot[]
  strategies         Strategy[]
  dashboardTemplates DashboardTemplate[]
  mochiUsage         MochiUsage[]
  forwardTests       ForwardTest[]

  @@map("users")
  @@schema("public")
}

// One Mochi (AI copilot) request's token usage, so we can meter per-plan limits
// over rolling windows (per 5 hours and per week) and show the user what they
// have spent.
model MochiUsage {
  id               String   @id @default(cuid())
  userId           String
  ts               DateTime @default(now())
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, ts])
  @@map("mochi_usage")
  @@schema("public")
}

// ─────────────────────── Dashboards ───────────────────────────

model DashboardTemplate {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isDefault Boolean  @default(false)
  layout    Json     // Array of widget definitions: { id, type, x, y, w, h, config }
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("dashboard_templates")
  @@schema("public")
}

// ─────────────────────── Accounts & Bots ────────────────────────

enum Broker {
  PAPER
  OANDA
  IBKR
  TRADOVATE
  ALPACA
  COINBASE
  BINANCE
  KRAKEN
  SCHWAB
  @@schema("public")
}

enum AccountMode {
  PAPER
  LIVE
  @@schema("public")
}

model Account {
  id         String      @id @default(cuid())
  userId     String
  nickname   String
  broker     Broker      @default(PAPER)
  mode       AccountMode @default(PAPER)
  externalId String?
  balance    Decimal     @default(10000) @db.Decimal(18, 2)
  currency                    String      @default("USD")
  maxDailyDrawdown            Decimal?    @db.Decimal(18, 2)
  isPropFirmMode              Boolean     @default(false)
  propFirmMaxTrailingDrawdown Decimal?    @db.Decimal(18, 2)
  isActive         Boolean     @default(true)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bot          Bot?
  connection   Connection?
  trades       Trade[]
  summaries    DailySummary[]
  agentEvents  AgentEvent[]
  forwardTests ForwardTest[]

  @@index([userId])
  @@map("accounts")
  @@schema("public")
}

enum BotStatus {
  RUNNING
  WAITING
  STOPPED
  @@schema("public")
}

model Bot {
  id                  String    @id @default(cuid())
  userId              String
  accountId           String?   @unique
  strategyId          String
  name                String    @default("My Bot")
  status              BotStatus @default(STOPPED)
  autoAdjustmentsUsed Int       @default(0)
  // Share of the portfolio risk budget allocated to this bot (percent).
  riskWeight          Decimal?  @db.Decimal(5, 2)
  // Edge-decay protection: pause flag + the relative win-rate drop that trips it.
  edgeDecayPaused     Boolean   @default(false)
  edgeDecayThreshold  Decimal?  @db.Decimal(5, 2)
  // Public proof-of-execution embed page toggle.
  isPublic            Boolean   @default(false)
  lastHeartbeat       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  account     Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)
  strategy    Strategy        @relation(fields: [strategyId], references: [id])
  trades      Trade[]
  adjustments BotAdjustment[]
  agentEvents AgentEvent[]

  @@index([userId])
  @@index([strategyId])
  @@map("bots")
  @@schema("public")
}

// ───────────────────────── Strategies ───────────────────────────

enum StrategyKind {
  ORB
  CUSTOM
  @@schema("public")
}

model Strategy {
  id        String       @id @default(cuid())
  userId    String
  name      String
  kind      StrategyKind @default(ORB)
  // Typed parameter set rendered by the Strategy Lab UI.
  params    Json
  version   Int          @default(1)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  bots         Bot[]
  adjustments  BotAdjustment[]
  forwardTests ForwardTest[]

  @@index([userId])
  @@map("strategies")
  @@schema("public")
}

// ─────────────────────────── Trades ─────────────────────────────

enum TradeDirection {
  LONG
  SHORT
  @@schema("public")
}

enum TradeSession {
  ASIA
  NY
  @@schema("public")
}

enum TradeStatus {
  OPEN
  CLOSED
  @@schema("public")
}

model Trade {
  id          String         @id @default(cuid())
  botId       String
  accountId   String
  instrument  String
  direction   TradeDirection
  session     TradeSession
  status      TradeStatus    @default(OPEN)

  entryPrice  Decimal  @db.Decimal(18, 5)
  exitPrice   Decimal? @db.Decimal(18, 5)
  stopPrice   Decimal  @db.Decimal(18, 5)
  targetPrice Decimal  @db.Decimal(18, 5)
  sizeUnits   Decimal  @db.Decimal(18, 4)
  riskPct     Decimal  @db.Decimal(6, 3)

  grossPnl   Decimal? @db.Decimal(18, 2)
  commission Decimal? @db.Decimal(18, 2)
  netPnl     Decimal? @db.Decimal(18, 2)
  rMultiple  Decimal? @db.Decimal(8, 3)
  mfe        Decimal? @db.Decimal(8, 3) // max favourable excursion (R)
  mae        Decimal? @db.Decimal(8, 3) // max adverse excursion (R)

  // Execution quality: what the bot intended vs what it actually filled, so a
  // trader can see whether automation is faithful (slippage in basis points,
  // positive = adverse) and how fast the entry routed.
  intendedEntryPrice Decimal? @db.Decimal(18, 5)
  entrySlippageBps   Decimal? @db.Decimal(10, 3)
  intendedExitPrice  Decimal? @db.Decimal(18, 5)
  exitSlippageBps    Decimal? @db.Decimal(10, 3)
  entryLatencyMs     Int?

  // Evidence-loop context buckets
  rangeBucket String? // SMALL | MEDIUM | LARGE
  entryBucket String? // FIRST_HOUR | LATER
  trendAgree  Boolean?

  screenshotUrl String?
  narrative     String?

  openedAt  DateTime  @default(now())
  closedAt  DateTime?
  createdAt DateTime  @default(now())

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, openedAt])
  @@index([botId])
  @@index([accountId, status])
  @@index([botId, status])
  @@map("trades")
  @@schema("public")
}

// ───────────────── Evidence-based optimisation ──────────────────

enum AdjustmentSource {
  BOT
  USER
  @@schema("public")
}

enum AdjustmentStatus {
  APPLIED
  PENDING
  REJECTED
  @@schema("public")
}

model BotAdjustment {
  id           String           @id @default(cuid())
  botId        String
  strategyId   String
  // Human-readable parameter label (for display) and the canonical schema key
  // (for application). paramKey lets approveSuggestion apply the change to
  // Strategy.params; oldValue/newValue store the raw values, formatted at render.
  parameter    String
  paramKey     String?
  oldValue     String
  newValue     String
  source       AdjustmentSource @default(BOT)
  status       AdjustmentStatus @default(APPLIED)
  reasoning    String?
  sampleSize   Int?
  winRateDelta Decimal?         @db.Decimal(6, 3)
  confidence   Decimal?         @db.Decimal(6, 3)
  createdAt    DateTime         @default(now())

  bot      Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)

  @@index([botId, createdAt])
  @@map("bot_adjustments")
  @@schema("public")
}

// ───────────────── Forward-test promotion gate ──────────────────

enum ForwardTestStatus {
  RUNNING
  PASSED
  FAILED
  STOPPED
  @@schema("public")
}

// A strategy proving itself in live paper ("shadow") trading before live capital
// is unlocked. Observed metrics are computed from the paper account's closed
// trades and compared to the validation baseline; status flips to PASSED only
// once enough trades confirm the edge held.
model ForwardTest {
  id                 String            @id @default(cuid())
  userId             String
  strategyId         String
  accountId          String
  status             ForwardTestStatus @default(RUNNING)
  targetTrades       Int               @default(20)
  baselineWinRate    Decimal?          @db.Decimal(6, 3)
  baselineExpectancy Decimal?          @db.Decimal(8, 3) // R per trade
  startedAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategy Strategy @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([accountId])
  @@map("forward_tests")
  @@schema("public")
}

// ─────────────────────── Daily summaries ────────────────────────

model DailySummary {
  id           String   @id @default(cuid())
  accountId    String
  date         DateTime @db.Date
  netPnl       Decimal  @default(0) @db.Decimal(18, 2)
  tradeCount   Int      @default(0)
  winCount     Int      @default(0)
  lossCount    Int      @default(0)
  startBalance Decimal  @db.Decimal(18, 2)
  endBalance   Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, date])
  @@map("daily_summaries")
  @@schema("public")
}

// ───────────────────────── News events ──────────────────────────

enum NewsImpact {
  LOW
  MEDIUM
  HIGH
  @@schema("public")
}

model NewsEvent {
  id        String     @id @default(cuid())
  eventTime DateTime
  currency  String
  impact    NewsImpact
  name      String
  createdAt DateTime   @default(now())

  @@index([eventTime])
  @@map("news_events")
  @@schema("public")
}

// ──────────────────── Broker connections (live) ─────────────────

// Encrypted broker credentials for a live account. `encrypted` holds an
// AES-256-GCM ciphertext (see src/lib/crypto.ts); secrets are never returned to
// the client and are decrypted only by the trading engine to place orders.
model Connection {
  id             String    @id @default(cuid())
  accountId      String    @unique
  provider       String
  encrypted      String
  status         String    @default("CONNECTED")
  lastVerifiedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("connections")
  @@schema("public")
}

// ───────────────────────── Agent feed ───────────────────────────

enum AgentEventKind {
  INFO
  SIGNAL
  TRADE
  RISK
  NEWS
  ADJUST
  @@schema("public")
}

// One narrated decision from the engine, powering the live agent feed.
// Trade.narrative remains the trade-level summary; this is the per-event stream.
model AgentEvent {
  id        String         @id @default(cuid())
  botId     String
  accountId String
  ts        DateTime       @default(now())
  kind      AgentEventKind @default(INFO)
  message   String
  tradeId   String?

  bot     Bot     @relation(fields: [botId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, ts])
  @@map("agent_events")
  @@schema("public")
}
