# Floqex environment variables. Copy to .env.local and fill with real values.

# ── Clerk (auth) ── https://dashboard.clerk.com
# For production, set the session cookie domain to .floqex.com so the session is
# shared across floqex.com, users.floqex.com, and accounts.floqex.com.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Auth routing — local dev / preview uses path-based routing (one host serves all).
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding

# Subdomain routing. Set NEXT_PUBLIC_ROOT_DOMAIN in production to switch the app
# to native subdomains: floqex.com (marketing), users.floqex.com (auth), and
# accounts.floqex.com (the account dashboard; dashboard.floqex.com also works).
# It drives src/lib/urls.ts link building AND the Clerk authorizedParties (azp)
# check in src/proxy.ts. Leave blank for local dev / previews.
# NEXT_PUBLIC_ROOT_DOMAIN=floqex.com
#
# Production Clerk URLs (uncomment alongside NEXT_PUBLIC_ROOT_DOMAIN):
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=https://users.floqex.com/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=https://users.floqex.com/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=https://accounts.floqex.com
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=https://accounts.floqex.com/onboarding
#
# Security: in the Clerk Dashboard, enable "Allowed Subdomains" (allowlist
# users + accounts + dashboard) instead of relying on default wildcard scoping,
# and keep the session cookie scoped to .floqex.com so it is shared across them.

# Clerk webhook signing secret (Clerk Dashboard > Webhooks). Used by
# /api/webhooks/clerk to sync users into the database.
CLERK_WEBHOOK_SIGNING_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Database (Supabase Postgres) ── https://supabase.com/dashboard
# DATABASE_URL: pooled connection (port 6543, pgbouncer) used by the app.
# DIRECT_URL:   direct connection (port 5432) used by Prisma migrations.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Supabase project (client-side, optional for storage/realtime later)
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxx

# ── Stripe (billing) ── https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# Signing secret for the subscription webhook (Developers > Webhooks). Point the
# endpoint at https://dashboard.floqex.com/api/webhooks/stripe and subscribe to
# checkout.session.completed and customer.subscription.created/updated/deleted.
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# Subscription price IDs (Products). The current Stripe test-mode prices are the
# defaults in src/lib/plans.ts; set these to your live price IDs in production.
# Set ALL three tiers. If a price id is unset or invalid, checkout falls back to
# an inline price built from the plan catalogue so the tier still works, but a
# real price id is preferred so Stripe reporting stays clean.
NEXT_PUBLIC_STRIPE_PRICE_TRADER=price_1TkeghDfBPHnomO3YsRzXVo7
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_1TkegrDfBPHnomO3qsVfTw0i
NEXT_PUBLIC_STRIPE_PRICE_ELITE=price_1TkegzDfBPHnomO3xxxxxxxx

# ── Security ──
# Secret used to AES-256-GCM encrypt live broker API keys at rest
# (src/lib/crypto.ts). Generate one with: openssl rand -base64 32
ENCRYPTION_KEY=

# ── Mochi AI assistant ── https://platform.openai.com/api-keys
# Used by src/app/api/chat (Vercel AI SDK). Without it the assistant is disabled.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Trading engine cron ──
# The engine runs as a scheduled route at /api/cron/engine (wired by the
# "crons" entry in vercel.json). Vercel automatically calls it with an
# Authorization: Bearer <CRON_SECRET> header ONLY if CRON_SECRET is set here, so
# this MUST be set in production or the engine never ticks and started bots do
# nothing. Generate one with: openssl rand -base64 32
CRON_SECRET=
# Optional shared secret for triggering the engine from an external scheduler
# (passed as ?secret=... or the x-api-secret header instead of the Bearer token).
API_SECRET=
